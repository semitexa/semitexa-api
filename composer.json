{
  "name": "semitexa/api",
  "description": "Semitexa API - external API product layer with machine credentials, versioned routes, and M2M contracts",
  "type": "semitexa-module",
  "license": "MIT",
  "authors": [
    {
      "name": "Semitexa",
      "email": "support@semitexa.com"
    }
  ],
  "require": {
    "php": "^8.4",
    "semitexa/core": "*",
    "semitexa/auth": "*"
  },
  "autoload": {
    "psr-4": {
      "Semitexa\\Api\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Semitexa\\Api\\Tests\\": "tests/"
    }
  },
  "extra": {
    "semitexa-module": {
      "extends": null
    }
  },
  "keywords": [
    "semitexa",
    "api",
    "m2m",
    "machine-auth",
    "versioning"
  ]
}
